# Lima configuration for kuberblue — generated by Ansible
images:
  - location: "{{ kuberblue_qcow2_path }}"
    arch: "x86_64"

cpus: {{ kuberblue_vm_cpus }}
memory: "{{ kuberblue_vm_memory_gb }}GiB"
disk: "{{ kuberblue_vm_disk_gb }}GiB"

# Skip Lima guest agent — bootc images are immutable, no cloud-init agent.
# In plain mode, limactl start will timeout waiting for the guest agent
# 'running' event. The Ansible role handles this by using --timeout and
# checking SSH directly.
plain: true

ssh:
  localPort: 0
  loadDotSSHPubKeys: true
  forwardAgent: false

firmware:
  legacyBIOS: false

containerd:
  system: false
  user: false

provision: []

# Attach the seed ISO for cloud-init NoCloud
additionalDisks:
  - name: "cidata"
    format: raw
