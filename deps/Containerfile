ARG FEDORA_VERSION=42

# =============================================================================
# Stage 1: Build GLib libraries and custom C projects
# Produces: /build/  (yaml-glib, crispy, gst, gowl, mcp-glib, podomation, etc.)
# =============================================================================
FROM registry.fedoraproject.org/fedora:${FEDORA_VERSION} AS dep-builder

COPY deps/00-build.sh /tmp/00-build.sh
COPY artifacts/overrides/usr/src/gitlab/yaml-glib /build/yaml-glib
COPY artifacts/overrides/usr/src/gitlab/crispy /build/crispy
COPY artifacts/overrides/usr/src/gitlab/gst /build/gst
COPY artifacts/overrides/usr/src/gitlab/gowl /build/gowl
COPY artifacts/overrides/usr/src/gitlab/mcp-glib /build/mcp-glib
COPY artifacts/overrides/usr/src/gitlab/mcp-gdb-glib /build/mcp-gdb-glib
COPY artifacts/overrides/usr/src/gitlab/ai-glib /build/ai-glib
COPY artifacts/overrides/usr/src/gitlab/podomation /build/podomation
COPY artifacts/overrides_kuberblue/usr/src/gitlab/mcp-kuberblue-glib /build/mcp-kuberblue-glib
RUN bash /tmp/00-build.sh

# =============================================================================
# Stage 2: Build NVIDIA kernel modules for the Cyan (GPU) variant
# Produces: /rpms/  (kmod-nvidia-*.rpm)
# =============================================================================
FROM quay.io/fedora/fedora:${FEDORA_VERSION} AS cyan-builder
ARG FEDORA_VERSION=42

RUN dnf install -y \
    https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-${FEDORA_VERSION}.noarch.rpm \
    https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-${FEDORA_VERSION}.noarch.rpm

RUN dnf update -y && \
    dnf install -y \
    akmods \
    mock \
    rpm-build \
    kernel \
    kernel-devel \
    kernel-headers \
    gcc \
    make \
    elfutils-libelf-devel

RUN dnf install -y akmod-nvidia

RUN mkdir -p /var/cache/akmods /rpms/nvidia

RUN KERNEL_VER=$(rpm -q kernel --queryformat '%{VERSION}-%{RELEASE}.%{ARCH}\n' | head -n1) && \
    akmods --kernels ${KERNEL_VER} --force

RUN find /var/cache/akmods -name "kmod-nvidia-*.rpm" -exec cp {} /rpms/nvidia/ \;

RUN cp /usr/src/akmods/akmod-nvidia-*.src.rpm /rpms/nvidia/ || true

# =============================================================================
# Final stage: single deps container with both /build and /rpms
# Each derivative pulls only what it needs via --mount=type=bind,from=build-deps
# =============================================================================
FROM scratch
COPY --from=dep-builder /build /build
COPY --from=cyan-builder /rpms /rpms
